@model IEnumerable<TicketWave.Repository.Entity.Member>
@{
    ViewData["Title"] = "會員管理";
    var showDeleted = ViewBag.ShowDeleted ?? false;
    var totalMembers = ViewBag.TotalMembers ?? 0;
    var activeMembers = ViewBag.ActiveMembers ?? 0;
    var deletedMembers = ViewBag.DeletedMembers ?? 0;
}

<div class="container-fluid">
    <!-- 標題列 -->
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fa fa-users me-2"></i> 會員管理</h2>
        </div>
    </div>

    <!-- ✅ 新增：統計卡片 -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body text-center">
                    <h6><i class="fa fa-users"></i> 總會員數</h6>
                    <h3 class="mb-0">@totalMembers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <h6><i class="fa fa-check-circle"></i> 活躍會員</h6>
                    <h3 class="mb-0">@activeMembers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white shadow-sm">
                <div class="card-body text-center">
                    <h6><i class="fa fa-user-times"></i> 已刪除會員</h6>
                    <h3 class="mb-0">@deletedMembers</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- ✅ 新增：訊息顯示 -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fa fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fa fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- 會員列表卡片 -->
    <div class="card">
        <div class="card-header bg-white">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">
                        @if (showDeleted)
                        {
                            <text>所有會員列表（含已刪除）</text>
                        }
                        else
                        {
                            <text>活躍會員列表</text>
                        }
                    </h5>
                </div>
                <div class="col-md-6">
                    <form method="get" class="d-flex">
                        <input type="hidden" name="showDeleted" value="@showDeleted" />
                        <input type="text"
                               name="searchTerm"
                               class="form-control me-2"
                               placeholder="搜尋姓名、Email、電話、身分證..."
                               value="@ViewBag.SearchTerm">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-search"></i> 搜尋
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ✅ 新增：切換按鈕列 -->
        <div class="card-body pb-0">
            <div class="btn-group mb-3" role="group">
                <a href="@Url.Action("Index", new { showDeleted = false })"
                   class="btn @(!showDeleted ? "btn-primary" : "btn-outline-primary")">
                    <i class="fa fa-users"></i> 活躍會員
                </a>
                <a href="@Url.Action("Index", new { showDeleted = true })"
                   class="btn @(showDeleted ? "btn-warning" : "btn-outline-warning")">
                    <i class="fa fa-list"></i> 所有會員
                </a>
                <a href="@Url.Action("DeletedMembers")"
                   class="btn btn-outline-danger">
                    <i class="fa fa-trash-alt"></i> 已刪除會員
                </a>
            </div>
        </div>

        <div class="card-body pt-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>姓名</th>
                                <th>Email</th>
                                <th>電話</th>
                                <th>身分證字號</th>
                                <th>狀態</th>
                                <th class="text-center">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model)
                            {
                                <!-- ✅ 已刪除會員用不同樣式 -->
                                var rowClass = member.IsDelete ? "table-danger" : "";
                                var statusBadge = member.IsDelete ? "badge bg-danger" : "badge bg-success";
                                var statusText = member.IsDelete ? "已刪除" : "正常";

                                <tr class="@rowClass">
                                    <td>
                                        <strong>@(member.Name ?? "未設定")</strong>
                                        @if (member.IsDelete)
                                        {
                                            <i class="fa fa-trash text-danger ms-1" title="已刪除"></i>
                                        }
                                    </td>
                                    <td>@member.Email</td>
                                    <td>@(member.Phone ?? "-")</td>
                                    <td>@(member.NationalID ?? "-")</td>
                                    <td>
                                        <span class="@statusBadge">@statusText</span>
                                    </td>
                                    <td class="text-center">
                                        <!-- ✅ 詳情按鈕 -->
                                        <a asp-action="Details"
                                           asp-route-id="@member.MemberId"
                                           class="btn btn-sm btn-info me-1"
                                           title="查看詳情">
                                            <i class="fa fa-eye"></i>
                                        </a>

                                        @if (!member.IsDelete)
                                        {
                                            <!-- ✅ 編輯按鈕（重置密碼） -->
                                            <button type="button"
                                                    class="btn btn-sm btn-warning me-1"
                                                    onclick="showResetPasswordModal('@member.MemberId', '@member.Name')"
                                                    title="重置密碼">
                                                <i class="fa fa-key"></i>
                                            </button>

                                            <!-- ✅ 刪除按鈕（軟刪除） -->
                                            <form asp-action="SoftDelete"
                                                  method="post"
                                                  style="display: inline;"
                                                  onsubmit="return confirm('確定要停用此會員帳號嗎？\n\n會員：@member.Name\nEmail：@member.Email\n\n停用後會員將無法登入，但資料會保留。')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@member.MemberId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-danger"
                                                        title="停用帳號">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <!-- ✅ 恢復按鈕（已刪除的會員） -->
                                            <form asp-action="Restore"
                                                  method="post"
                                                  style="display: inline;"
                                                  onsubmit="return confirm('確定要恢復此會員帳號嗎？\n\n恢復後會員即可重新登入。')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@member.MemberId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-success"
                                                        title="恢復帳號">
                                                    <i class="fa fa-undo"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <p class="text-muted">
                        共 @Model.Count() 位會員
                        @if (showDeleted)
                        {
                            <span>（含 @deletedMembers 位已刪除）</span>
                        }
                    </p>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fa fa-users fa-3x text-muted mb-3"></i>
                    <p class="text-muted">
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                        {
                            <text>找不到符合「@ViewBag.SearchTerm」的會員</text>
                        }
                        else if (showDeleted)
                        {
                            <text>目前沒有任何會員</text>
                        }
                        else
                        {
                            <text>目前沒有活躍會員</text>
                        }
                    </p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ✅ 重置密碼 Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa fa-key"></i> 重置會員密碼
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="resetPasswordForm" method="post" asp-action="ResetPassword">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="resetMemberId" name="memberId" />

                    <div class="alert alert-warning">
                        <i class="fa fa-exclamation-triangle"></i>
                        <strong>注意：</strong>此操作將重置會員密碼為預設密碼
                    </div>

                    <p>
                        會員：<strong id="resetMemberName"></strong>
                    </p>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">
                            新密碼 <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               class="form-control"
                               id="newPassword"
                               name="newPassword"
                               required
                               value="Password123" />
                        <small class="text-muted">預設密碼：Password123</small>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               id="sendEmail"
                               name="sendEmail"
                               checked />
                        <label class="form-check-label" for="sendEmail">
                            發送通知郵件給會員
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        取消
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-check"></i> 確定重置
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 顯示重置密碼 Modal
        function showResetPasswordModal(memberId, memberName) {
            document.getElementById('resetMemberId').value = memberId;
            document.getElementById('resetMemberName').textContent = memberName;

            // 使用 Bootstrap 5 的方式
            var modal = new bootstrap.Modal(document.getElementById('resetPasswordModal'));
            modal.show();
        }

        // 自動隱藏提示訊息
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert-dismissible');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}

<style>
    .table-danger {
        background-color: #f8d7da !important;
    }

    .card {
        border-radius: 0.5rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    .btn-group .btn {
        font-weight: 500;
    }

    .badge {
        font-size: 0.875rem;
        padding: 0.375rem 0.75rem;
    }
</style>
