<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketWave 後台管理系統</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Microsoft JhengHei', Arial, sans-serif;
        }

        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            padding: 0;
            box-shadow: inset -1px 0 0 rgba(0, 0, 0, .1);
            background: #2c3e50;
        }

        .sidebar-sticky {
            position: relative;
            top: 0;
            height: calc(100vh - 48px);
            padding-top: .5rem;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .sidebar .nav-link {
            font-weight: 500;
            color: #ecf0f1;
            padding: 15px 20px;
            border-left: 3px solid transparent;
        }

            .sidebar .nav-link:hover {
                color: #fff;
                background: #34495e;
                border-left-color: #3498db;
            }

            .sidebar .nav-link.active {
                color: #fff;
                background: #34495e;
                border-left-color: #3498db;
            }

            .sidebar .nav-link i {
                margin-right: 10px;
                width: 20px;
            }

        .sidebar-heading {
            font-size: .75rem;
            text-transform: uppercase;
            color: #95a5a6;
            padding: 15px 20px 5px;
        }

        .navbar {
            background: #fff;
            box-shadow: 0 2px 4px rgba(0,0,0,.08);
        }

        main {
            margin-left: 240px;
            padding: 20px;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

            .stat-card.success {
                background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            }

            .stat-card.warning {
                background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            }

            .stat-card.info {
                background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            }
    </style>
</head>
<body>
    <!-- 側邊欄 -->
    <nav class="sidebar" style="width: 240px;">
        <div class="sidebar-sticky">
            <div class="text-center p-3" style="background: #1a252f;">
                <h4 class="text-white mb-0">
                    <i class="fa fa-ticket-alt"></i> TicketWave
                </h4>
                <small class="text-muted">後台管理系統</small>
            </div>

            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                        <i class="fa fa-tachometer-alt"></i> 儀表板
                    </a>
                </li>
                <li class="sidebar-heading">管理功能</li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Concert" asp-action="Index">
                        <i class="fa fa-music"></i> 演唱會管理
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Member" asp-action="Index">
                        <i class="fa fa-users"></i> 會員管理
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Order" asp-action="Index">
                        <i class="fa fa-shopping-cart"></i> 訂單管理
                    </a>
                </li>
                <li class="sidebar-heading">系統</li>
                <li class="nav-item">
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("AdminUsername")))
                    {
                        <!-- 已登入：顯示登出按鈕 -->
                        <form asp-controller="Account" asp-action="Logout" method="post" style="margin: 0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link border-0 w-100 text-start" style="background: transparent;">
                                <i class="fa fa-sign-out-alt"></i> 登出
                            </button>
                        </form>
                    }
                    else
                    {
                        <!-- 未登入：顯示登入連結 -->
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            <i class="fa fa-sign-in-alt"></i> 登入
                        </a>
                    }
                </li>
            </ul>
        </div>
    </nav>

    <!-- 主要內容 -->
    <main>
        <!-- 頂部導覽列 -->
        @if (!string.IsNullOrEmpty(Context.Session.GetString("AdminUsername")))
        {
            <!-- 已登入：顯示導覽列 -->
            <nav class="navbar navbar-expand-lg navbar-light mb-4">
                <div class="container-fluid">
                    <span class="navbar-brand mb-0 h1">@ViewData["Title"]</span>
                    <div class="ms-auto">
                        <span class="text-muted">
                            <i class="fa fa-user-circle"></i>
                            管理員：@Context.Session.GetString("AdminUsername")
                        </span>
                    </div>
                </div>
            </nav>
        }

        <!-- 訊息提示 -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fa fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- 頁面內容 -->
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
