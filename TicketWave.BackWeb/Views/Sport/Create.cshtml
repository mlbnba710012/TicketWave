@model TicketWave.Repository.Entity.Sport

@{
    ViewData["Title"] = "新增體育賽事";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fa fa-plus me-2"></i> 新增體育賽事</h2>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SportName" class="form-label">賽事名稱 <span class="text-danger">*</span></label>
                        <input asp-for="SportName" class="form-control" placeholder="例如：P.LEAGUE+ 林志傑引退賽" />
                        <span asp-validation-for="SportName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="SportType" class="form-label">運動類型 <span class="text-danger">*</span></label>
                        <input asp-for="SportType" class="form-control" placeholder="例如：籃球、棒球、足球" />
                        <span asp-validation-for="SportType" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="HomeTeam" class="form-label">主場隊伍 <span class="text-danger">*</span></label>
                        <input asp-for="HomeTeam" class="form-control" placeholder="例如：臺北富邦勇士" />
                        <span asp-validation-for="HomeTeam" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="AwayTeam" class="form-label">客場隊伍 <span class="text-danger">*</span></label>
                        <input asp-for="AwayTeam" class="form-control" placeholder="例如：桃園璞園領航猿" />
                        <span asp-validation-for="AwayTeam" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="League" class="form-label">聯賽名稱</label>
                        <input asp-for="League" class="form-control" placeholder="例如：P.LEAGUE+" />
                        <span asp-validation-for="League" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Season" class="form-label">賽季</label>
                        <input asp-for="Season" class="form-control" placeholder="例如：2025-26" />
                        <span asp-validation-for="Season" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="PerformanceDate" class="form-label">比賽日期時間 <span class="text-danger">*</span></label>
                        <input asp-for="PerformanceDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="PerformanceDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="TotalSeats" class="form-label">總座位數 <span class="text-danger">*</span></label>
                        <input asp-for="TotalSeats" type="number" class="form-control" min="1" placeholder="例如：500" />
                        <span asp-validation-for="TotalSeats" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="VenueName" class="form-label">場館名稱 <span class="text-danger">*</span></label>
                        <input asp-for="VenueName" class="form-control" placeholder="例如：臺北大巨蛋" />
                        <span asp-validation-for="VenueName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="VenueAddress" class="form-label">場館地址</label>
                        <input asp-for="VenueAddress" class="form-control" placeholder="例如：台北市信義區忠孝東路五段1號" />
                        <span asp-validation-for="VenueAddress" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="SaleStartDate" class="form-label">開始售票時間 <span class="text-danger">*</span></label>
                        <input asp-for="SaleStartDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="SaleStartDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="SaleEndDate" class="form-label">結束售票時間 <span class="text-danger">*</span></label>
                        <input asp-for="SaleEndDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="SaleEndDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Status" class="form-label">賽事狀態 <span class="text-danger">*</span></label>
                        <select asp-for="Status" class="form-select">
                            <option value="0">未開賣</option>
                            <option value="1" selected>售票中</option>
                            <option value="2">已售罄</option>
                            <option value="3">已結束</option>
                            <option value="4">已取消</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Description" class="form-label">賽事描述</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="賽事的詳細說明..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="PosterImageUrl" class="form-label">海報圖片 URL</label>
                        <input asp-for="PosterImageUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="PosterImageUrl" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-save"></i> 儲存
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa fa-times"></i> 取消
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
