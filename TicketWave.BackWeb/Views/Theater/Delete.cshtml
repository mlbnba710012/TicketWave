@model TicketWave.Repository.Entity.Theater

@{
    ViewData["Title"] = "刪除表演藝術";
    var hasOrders = ViewBag.HasOrders as bool? ?? false;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fa fa-trash me-2"></i> 刪除表演藝術</h2>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (hasOrders)
            {
                <div class="alert alert-danger">
                    <h5 class="alert-heading">
                        <i class="fa fa-exclamation-triangle"></i> 無法刪除此表演
                    </h5>
                    <p class="mb-0">此表演已有訂單記錄，無法刪除。請考慮將表演狀態設為「已取消」。</p>
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    <h5 class="alert-heading">
                        <i class="fa fa-exclamation-triangle"></i> 確認刪除
                    </h5>
                    <p class="mb-0">您確定要刪除以下表演嗎？此操作無法復原。</p>
                </div>
            }

            <div class="table-responsive mt-4">
                <table class="table">
                    <tr>
                        <th style="width: 200px;">表演名稱</th>
                        <td>@Model.TheaterName</td>
                    </tr>
                    <tr>
                        <th>表演類型</th>
                        <td>@Model.TheaterType</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.Director))
                    {
                        <tr>
                            <th>導演</th>
                            <td>@Model.Director</td>
                        </tr>
                    }
                    @if (Model.Duration.HasValue)
                    {
                        <tr>
                            <th>演出時長</th>
                            <td>@Model.Duration 分鐘</td>
                        </tr>
                    }
                    <tr>
                        <th>演出日期</th>
                        <td>@Model.PerformanceDate.ToString("yyyy/MM/dd HH:mm")</td>
                    </tr>
                    <tr>
                        <th>場館</th>
                        <td>@Model.VenueName (@Model.VenueAddress)</td>
                    </tr>
                    <tr>
                        <th>總座位數</th>
                        <td>@Model.TotalSeats</td>
                    </tr>
                    <tr>
                        <th>剩餘座位</th>
                        <td>@Model.AvailableSeats</td>
                    </tr>
                    <tr>
                        <th>已售票數</th>
                        <td>@(Model.TotalSeats - Model.AvailableSeats)</td>
                    </tr>
                    <tr>
                        <th>狀態</th>
                        <td>
                            @switch (Model.Status)
                            {
                                case 0: <span class="badge bg-secondary">未開賣</span> break;
                                case 1: <span class="badge bg-success">售票中</span> break;
                                case 2: <span class="badge bg-danger">已售罄</span> break;
                                case 3: <span class="badge bg-dark">已結束</span> break;
                                case 4: <span class="badge bg-warning">已取消</span> break;
                            }
                        </td>
                    </tr>
                </table>
            </div>

            <div class="mt-4">
                @if (!hasOrders)
                {
                    <form asp-action="Delete" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="TheaterId" />
                        <button type="submit" class="btn btn-danger" onclick="return confirm('確定要刪除此表演嗎？');">
                            <i class="fa fa-trash"></i> 確認刪除
                        </button>
                    </form>
                }
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fa fa-arrow-left"></i> 返回列表
                </a>
            </div>
        </div>
    </div>
</div>
