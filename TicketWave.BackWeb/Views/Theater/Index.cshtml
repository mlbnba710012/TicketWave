@model IEnumerable<TicketWave.Repository.Entity.Theater>

@{
    ViewData["Title"] = "表演藝術管理";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2><i class="fa fa-ticket me-2"></i> 表演藝術管理</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa fa-plus"></i> 新增表演
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">表演藝術列表</h5>
            <span class="badge bg-primary">共 @Model.Count() 場表演</span>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>表演名稱</th>
                                <th>類型</th>
                                <th>導演</th>
                                <th>演出日期</th>
                                <th>場館</th>
                                <th>總座位數</th>
                                <th>剩餘座位</th>
                                <th style="width: 200px;">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var theater in Model)
                            {
                                var soldSeats = theater.TotalSeats - theater.AvailableSeats;
                                var soldPercentage = theater.TotalSeats > 0 ? (soldSeats * 100.0 / theater.TotalSeats) : 0;
                                <tr>
                                    <td><strong>@theater.TheaterName</strong></td>
                                    <td><span class="badge" style="background-color:#764ba2;">@theater.TheaterType</span></td>
                                    <td>@(string.IsNullOrEmpty(theater.Director) ? "-" : theater.Director)</td>
                                    <td>@theater.PerformanceDate.ToString("yyyy/MM/dd HH:mm")</td>
                                    <td>@theater.VenueName</td>
                                    <td>@theater.TotalSeats</td>
                                    <td>
                                        @theater.AvailableSeats
                                        <small class="text-muted">(@soldPercentage.ToString("F1")% 已售)</small>
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@theater.TheaterId" class="btn btn-sm btn-info" title="詳情">
                                            <i class="fa fa-eye"></i> 詳情
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@theater.TheaterId" class="btn btn-sm btn-warning" title="編輯">
                                            <i class="fa fa-edit"></i> 編輯
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@theater.TheaterId" class="btn btn-sm btn-danger" title="刪除">
                                            <i class="fa fa-trash"></i> 刪除
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fa fa-ticket fa-3x text-muted mb-3"></i>
                    <p class="text-muted mb-3">目前沒有表演藝術</p>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fa fa-plus"></i> 新增第一場表演
                    </a>
                </div>
            }
        </div>
    </div>
</div>
