@model List<TicketWave.Repository.Entity.Theater>
@{
    ViewData["Title"] = "Theater";
}

<section class="banner">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-6">
                        <h1 class="banner-header">Theater</h1>
                    </div>
                    <div class="col-md-6">
                        <p class="banner-nav">
                            <span class="banner-box">
                                <a href="/Home/index">Home</a>
                                <a href="/Theater/Index">Theater</a>
                            </span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about">
    <div class="container">
        <header class="section-header">
            <h3>Theater</h3>
        </header>

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info text-center">
                <h4>目前沒有表演藝術資訊</h4>
                <p>請稍後再回來查看</p>
            </div>
        }
        else
        {
            @if (Model.Count > 0)
            {
                var first = Model[0];
                <div class="row">
                    <div class="col-md-4 about-col-1">
                        <div class="about-title">
                            <h1>Welcome to @first.TheaterName</h1>
                            <a asp-controller="Theater"
                               asp-action="SelectZone"
                               asp-route-theaterId="@first.TheaterId">
                                Buy Tickets
                            </a>
                        </div>
                    </div>
                    <div class="col-md-8 about-col-2">
                        <div class="about-imgs">
                            <div class="about-img">
                                @if (!string.IsNullOrEmpty(first.PosterImageUrl))
                                {
                                    <img class="img-fluid" src="@first.PosterImageUrl" alt="@first.TheaterName" />
                                }
                                else
                                {
                                    <img class="img-fluid" src="~/img/theater-1.png" alt="@first.TheaterName" />
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12 about-des">
                        <div class="row">
                            @for (int i = 1; i < Model.Count && i < 4; i++)
                            {
                                var theater = Model[i];
                                var imagePath = $"~/img/theater-{i + 1}.png";
                                <div class="col-md-6">
                                    <div class="about-des-col">
                                        <div class="about-img">
                                            @if (!string.IsNullOrEmpty(theater.PosterImageUrl))
                                            {
                                                <img class="img-fluid" src="@theater.PosterImageUrl" alt="@theater.TheaterName" />
                                            }
                                            else
                                            {
                                                <img class="img-fluid" src="@imagePath" alt="@theater.TheaterName" />
                                            }
                                        </div>
                                        <p>
                                            <strong>@theater.TheaterName</strong><br />
                                            @if (!string.IsNullOrEmpty(theater.Description))
                                            {
                                                @theater.Description
                                                <br />
                                            }
                                            <i class="fa fa-ticket"></i> 類型：@theater.TheaterType<br />
                                            <i class="fa fa-calendar"></i> 時間：@theater.PerformanceDate.ToString("yyyy/MM/dd HH:mm")<br />
                                            <i class="fa fa-map-marker-alt"></i> 地點：@theater.VenueName
                                        </p>
                                        <a asp-controller="Theater"
                                           asp-action="SelectZone"
                                           asp-route-theaterId="@theater.TheaterId">
                                            Buy Tickets
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>
