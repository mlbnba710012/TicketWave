}

<!-- Banner Section Start-->
<section class="banner">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-6">
                        <h1 class="banner-header">
                            登入會員
                        </h1>
                    </div>
                    <div class="col-md-6">
                        <p class="banner-nav">
                            <span class="banner-box">
                                <a href="/Home/Index">Home</a>
                                <a href="/Member/Login">User Area</a>
                            </span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Banner Section end -->
<!-- Login Section Start -->
<section id="login">
    <div class="container">
        <div class="section-header">
            <h3>登入會員</h3>
        </div>
        <div class="row">
            <div class="col-md-3 form"></div>
            <div class="col-md-6 form">
                <form asp-action="Login" method="post">
                    <div class="form-row">
                       
                        <div class="form-group col-md-12">
                            <input type="email" name="email" class="form-control" placeholder="Your Email" value="xiulan26@liu.org" />
                            @* <input type="email" name="email" class="form-control" placeholder="Your Email" value="test@cc.com.tw" /> *@
                        </div>
                       
                        <div class="form-group col-md-12">
                            <input type="password" name="password" class="form-control" placeholder="Your Password" value="pwd9006" />
                            @* <input type="password" name="password" class="form-control" placeholder="Your Password" value="test123" /> *@
                        </div>
                        
                        <div class="form-group col-md-12">
                            <button type="submit">Sign In</button>
                        </div>

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
                        {
                            <div style="color:red; background-color: #ffebee; padding: 15px; border-radius: 5px; margin-bottom: 15px;">
                                @foreach (var error in ViewData.ModelState[""].Errors)
                                {
                                    <p style="margin: 5px 0;"><strong>⚠️ @error.ErrorMessage</strong></p>
                                }
                            </div>
                        }
                        @* <p style="color:red">
                            @ViewBag.ErrorMessage
                        </p> *@
                    </div>

                    @* <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="remember1">
                            <label class="custom-control-label" for="remember1">Remember me</label>
                        </div>
                    </div> *@
                    @* <div><button type="submit">Sing Up</button></div> *@
                </form>
                <div class="col-md-3 form"></div>
            </div>

            @* <div class="col-md-6 form">
                <form>
                    <div class="form-group">
                        <input type="email" class="form-control" placeholder="Your Email" />
                    </div>
                    <div class="form-group">
                        <input type="password" class="form-control" placeholder="Your Password" />
                    </div>
                    <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="remember2">
                            <label class="custom-control-label" for="remember2">Remember me</label>
                        </div>
                    </div>
                    <div><button type="submit">Sign In</button></div>
                </form>
            </div> *@
        </div>
    </div>
</section>
<!-- Login Section end -->
